# ─── Ports ────────────────────────────────────────────────────────────────────
PORT=8080
FRONTEND_PORT=3000
POSTGRES_PORT=5432
REDIS_PORT=6379
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# ─── Database ─────────────────────────────────────────────────────────────────
POSTGRES_DB=learnflow
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# ─── Backend ──────────────────────────────────────────────────────────────────
ENV=local
SERVER_TIMEOUT=30
JWT_SECRET=dev-secret-change-me

# ─── Storage (local: MinIO, prod: Cloudflare R2) ──────────────────────────────
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET=learnflow
STORAGE_REGION=us-east-1

# ─── Email ────────────────────────────────────────────────────────────────────
# EMAIL_PROVIDER: stub | resend
EMAIL_PROVIDER=stub
EMAIL_FROM=noreply@learnflow.local
RESEND_API_KEY=

# ─── Payments ─────────────────────────────────────────────────────────────────
# Stripe (test keys: https://dashboard.stripe.com/test/apikeys)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Przelewy24 (sandbox: https://sandbox.przelewy24.pl)
P24_MERCHANT_ID=
P24_API_KEY=
P24_WEBHOOK_SECRET=

# ─── Frontend (Nuxt 3) ────────────────────────────────────────────────────────
NUXT_PUBLIC_API_BASE_URL=http://localhost:8080
NUXT_PUBLIC_SITE_URL=http://localhost:3000
# Leave empty locally — scripts won't load without valid IDs
NUXT_PUBLIC_GA_ID=
NUXT_PUBLIC_GOOGLE_ADS_ID=
NUXT_PUBLIC_COOKIEBOT_ID=
